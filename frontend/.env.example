# 后端 API 地址（推荐生产环境显式配置）
VITE_API_BASE=/api/v1

# WebSocket 地址（留空时自动按 window.location 推导）
VITE_WS_BASE=

# 管理接口鉴权 Token（对应后端 ADMIN_TOKEN）
VITE_AUTH_TOKEN=change-me-admin-token

# Vite 允许访问主机（逗号分隔）
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Vite 本地代理目标（开发模式）
VITE_API_PROXY_TARGET=http://localhost:8100

# HMR 客户端端口（容器映射时可设为外部端口）
VITE_HMR_CLIENT_PORT=5174

# 百度地图 AK（需要在百度地图开放平台申请）
VITE_BAIDU_AK=your_baidu_map_ak_here

# 默认地图中心点经度（北京天安门附近）
VITE_DEFAULT_LONGITUDE=116.3650

# 默认地图中心点纬度（北京天安门附近）
VITE_DEFAULT_LATITUDE=40.0095
