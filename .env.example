# 数据库连接 URL（格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/seed_monitor

# 数据上报接口的认证令牌（C程序调用 /ingest 接口时需要在 Header 中携带）
INGEST_TOKEN=change-me-ingest-token

# 管理接口认证令牌（前端与管理脚本调用 /runs*、/report、/ws 需要）
ADMIN_TOKEN=change-me-admin-token

# 数据库批量写入最大条数（达到此数量立即写入）
DB_BATCH_MAX_SIZE=500

# 数据库批量写入最大延迟（毫秒，超过此时间立即写入）
DB_BATCH_MAX_LATENCY_MS=500

# 队列高水位线（队列积压超过此数量时触发背压保护）
QUEUE_HIGH_WATERMARK=2000

# 遥测数据 WebSocket 推送频率（Hz，每秒推送次数）
TELEMETRY_PUSH_HZ=5

# GPS 数据 WebSocket 推送频率（Hz，每秒推送次数）
GPS_PUSH_HZ=1

# 数据保留天数（超过此天数的数据将被自动清理）
RETENTION_DAYS=30

# CORS 允许的源（逗号分隔，生产环境请填写实际域名）
CORS_ALLOW_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# 日志等级（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
