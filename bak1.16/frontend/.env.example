# 后端 API 地址
VITE_API_BASE=http://localhost:8200/api/v1

# WebSocket 地址
VITE_WS_BASE=ws://localhost:8200

# 设备标识符（用于区分不同的播种机）
VITE_MACHINE_ID=machine-001

# 百度地图 AK（需要在百度地图开放平台申请）
VITE_BAIDU_AK=your_baidu_map_ak_here

# 默认地图中心点经度（北京天安门附近）
VITE_DEFAULT_LONGITUDE=116.3650

# 默认地图中心点纬度（北京天安门附近）
VITE_DEFAULT_LATITUDE=40.0095
